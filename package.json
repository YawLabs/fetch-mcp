{
  "name": "@yawlabs/fetch-mcp",
  "version": "0.3.0",
  "description": "Comprehensive HTTP fetch MCP server: SSRF protection, HTML-to-markdown, reader-mode, metadata / link / sitemap / RSS-Atom extraction, robots.txt verdicts",
  "license": "MIT",
  "author": "Yaw Labs <support@mcp.hosting> (https://mcp.hosting)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "bin": {
    "fetch-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "test:ci": "npm run build && npm test",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-xml-parser": "^5.7.1",
    "turndown": "^7.2.1",
    "undici": "^7.25.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^25.6.0",
    "@types/turndown": "^5.0.5",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "fetch",
    "http",
    "web",
    "scraping",
    "markdown",
    "ssrf",
    "robots",
    "sitemap",
    "rss",
    "atom",
    "opengraph",
    "reader-mode",
    "mcp-server",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YawLabs/fetch-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/YawLabs/fetch-mcp/issues"
  },
  "homepage": "https://github.com/YawLabs/fetch-mcp"
}
